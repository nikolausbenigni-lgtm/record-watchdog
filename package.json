<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RecordWatchdog | Public Records Directory</title>
  <meta name="description" content="Search public record resources, business entities, lawsuit records, incarceration records, bankruptcy tools, and registry directories." />
  <link rel="icon" href="./recordwatchdog-logo.png" />
  <style>
    *{box-sizing:border-box}html{scroll-behavior:smooth}body{margin:0;font-family:Inter,Arial,sans-serif;background:#f4f2ee;color:#101943}a{text-decoration:none;color:inherit}button,select,input{font:inherit}.wrap{max-width:1180px;margin:0 auto;padding:0 20px}.header{position:sticky;top:0;z-index:50;background:rgba(251,250,247,.96);backdrop-filter:blur(12px);border-bottom:1px solid #e5ded4;box-shadow:0 2px 12px rgba(16,25,67,.06)}.header-row{height:92px;display:flex;align-items:center;justify-content:space-between;gap:22px}.logo{display:block;height:76px;width:auto;max-width:340px;object-fit:contain}.nav{display:flex;gap:18px;font-size:13px;font-weight:900}.nav a:hover{color:#ff6f36}.hero{position:relative;overflow:hidden;background:#071638;color:#fff}.hero:before{content:"";position:absolute;inset:0;background:radial-gradient(circle at 15% 20%,rgba(255,255,255,.14),transparent 28%),radial-gradient(circle at 82% 8%,rgba(255,111,54,.16),transparent 24%)}.hero-grid{position:relative;display:grid;grid-template-columns:1.3fr .7fr;gap:54px;padding:70px 20px}.h1{font-size:64px;line-height:1.04;margin:0;font-weight:1000;letter-spacing:-.04em}.orange{color:#ff6f36}.lead{margin:24px 0 0;max-width:760px;font-size:21px;line-height:1.6;color:#dfe5f1}.badges{display:flex;flex-wrap:wrap;gap:10px;margin-top:28px}.badge{border:1px solid rgba(255,255,255,.2);background:rgba(255,255,255,.1);border-radius:999px;padding:9px 14px;font-weight:900;font-size:14px}.state-card{margin-top:36px;max-width:650px;background:#fff;border:1px solid rgba(255,255,255,.25);border-radius:28px;padding:24px;box-shadow:0 22px 60px rgba(0,0,0,.25)}.label{display:block;margin-bottom:10px;color:#64748b;font-size:13px;font-weight:1000;text-transform:uppercase;letter-spacing:.14em}.state-grid{display:grid;grid-template-columns:1fr 240px;gap:14px}select,input{width:100%;border:1px solid #cbd5e1;border-radius:14px;padding:16px 18px;outline:none;background:#fff;color:#101943;font-weight:800}.btn{display:inline-flex;align-items:center;justify-content:center;min-height:58px;padding:16px 22px;border-radius:14px;background:#ff6f36;color:#fff;font-weight:1000;box-shadow:0 10px 24px rgba(255,111,54,.24);border:0;cursor:pointer}.btn.dark{background:#101943}.btn:hover{transform:translateY(-1px)}.quick-row{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:30px}.quick-card,.card,.panel{background:#fffdf9;border:1px solid #e4ded5;border-radius:24px;padding:22px;box-shadow:0 14px 35px rgba(16,25,67,.06)}.quick-card{background:#13224d;color:#fff;border-color:rgba(255,255,255,.15);cursor:pointer}.quick-card:hover{border-color:#ff6f36;background:#1a2d63}.ad-label{text-align:right;margin:0 0 8px;font-size:9px;text-transform:uppercase;letter-spacing:.18em;font-weight:900;color:#cbd5e1}.ad-box{height:220px;border-radius:22px;background:#ebe5dc}.ad-box.small{height:140px}.hero-side{display:grid;align-content:center;gap:28px}.trust{display:grid;gap:22px;color:#dfe5f1}.trust h3{margin:0 0 8px;color:#fff;font-size:22px}.trust p{margin:0;line-height:1.55}.quick-section{padding:42px 0;border-bottom:1px solid #e2ddd4;background:#f7f4ef}.eyebrow{margin:0;text-transform:uppercase;letter-spacing:.2em;font-size:13px;font-weight:1000;color:#ff6f36}.h2{margin:10px 0 0;font-size:42px;line-height:1.1;font-weight:1000;letter-spacing:-.02em}.state-buttons{display:grid;grid-template-columns:repeat(6,1fr);gap:14px;margin-top:24px}.state-btn{text-align:left;border:1px solid #e3ddd3;background:#fffdf9;border-radius:24px;padding:20px;box-shadow:0 14px 35px rgba(16,25,67,.06);cursor:pointer}.state-btn:hover{border-color:#ff6f36}.section{padding:68px 0;position:relative;overflow:hidden}.section.alt{background:linear-gradient(#fbfaf7,#f1eee8);border-top:1px solid #e2ddd4;border-bottom:1px solid #e2ddd4}.section p.desc{max-width:760px;color:#64748b;line-height:1.65}.grid3{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:32px}.grid2{display:grid;grid-template-columns:repeat(2,1fr);gap:22px;margin-top:32px}.icon{width:52px;height:52px;border-radius:14px;background:#fff1e8;color:#ff6f36;display:flex;align-items:center;justify-content:center;font-weight:1000;font-size:25px;margin-bottom:16px}.card h3,.panel h3{margin:0;font-size:20px}.card p,.panel p{color:#64748b;line-height:1.65}.form-row{display:grid;grid-template-columns:1fr 240px;gap:14px;margin-top:20px}.chips{display:flex;flex-wrap:wrap;gap:10px;margin-top:24px}.chip{border:1px solid #d8d1c7;background:#f7f4ef;border-radius:999px;padding:10px 16px;font-weight:900;color:#475569;cursor:pointer}.chip:hover{border-color:#ff6f36;color:#ff6f36;background:#fff7ed}.footer{background:#071638;color:#fff;padding:42px 0}.footer-row{display:flex;align-items:center;justify-content:space-between;gap:24px}.footer .logo{height:70px}.footer-links{display:flex;flex-wrap:wrap;gap:18px;color:#cbd5e1;font-weight:900;font-size:14px}.modal{display:none;position:fixed;inset:0;z-index:100;background:rgba(0,0,0,.6);padding:20px;align-items:center;justify-content:center}.modal.active{display:flex}.modal-card{position:relative;max-width:850px;max-height:90vh;overflow:auto;background:#fff;border-radius:28px;padding:34px;box-shadow:0 24px 80px rgba(0,0,0,.3)}.close{position:absolute;right:18px;top:18px;border:1px solid #e2e8f0;background:#fff;border-radius:999px;padding:8px 12px;cursor:pointer}.mobile-btn{display:none}
    @media(max-width:980px){.hero-grid{grid-template-columns:1fr}.h1{font-size:48px}.grid3,.grid2,.state-buttons{grid-template-columns:1fr 1fr}.nav{display:none}.mobile-btn{display:block}.state-grid,.form-row{grid-template-columns:1fr}.footer-row{align-items:flex-start;flex-direction:column}.logo{height:64px;max-width:300px}}@media(max-width:640px){.header-row{height:auto;padding:12px 0}.logo{height:54px;max-width:250px}.h1{font-size:40px}.lead{font-size:18px}.quick-row,.grid3,.grid2,.state-buttons{grid-template-columns:1fr}.hero-grid{padding:48px 20px}.h2{font-size:34px}}
  </style>
</head>
<body>
  <header class="header"><div class="wrap header-row"><a href="#top"><img class="logo" src="./recordwatchdog-logo.png" alt="RecordWatchdog logo"></a><nav class="nav"><a href="#business">Business</a><a href="#court">Lawsuits</a><a href="#inmates">Incarceration</a><a href="#bankruptcy">Bankruptcy</a><a href="#sex">Sex Offenders</a></nav></div></header>
  <main id="top">
    <section class="hero"><div class="wrap hero-grid"><div><h1 class="h1">Search Public Records.<br><span class="orange">Find What Matters.</span></h1><p class="lead">Start with a state, then access business entity search, lawsuit records, incarceration records, bankruptcy tools, and sex offender registry resources.</p><div class="badges"><span class="badge">50 State Directories</span><span class="badge">Official Sources</span><span class="badge">Privacy-Friendly</span></div><div class="state-card"><label class="label">Select Your State</label><div class="state-grid"><select id="stateSelect"></select><button class="btn" onclick="scrollToId('business')">Show Options</button></div></div><div class="quick-row"><button class="quick-card" onclick="popular('Florida','business')"><strong>Florida Records</strong><br><small>Most searched state</small></button><button class="quick-card" onclick="popular('California','court')"><strong>California Courts</strong><br><small>High traffic lookups</small></button><button class="quick-card" onclick="popular('Texas','business')"><strong>Texas Business Search</strong><br><small>Popular entity searches</small></button></div></div><div class="hero-side"><div><p class="ad-label">Advertisement</p><div class="ad-box"></div></div><div class="trust"><div><h3>Trusted & Secure</h3><p>Official sources, state court systems, and privacy-friendly navigation.</p></div><div><h3>Official Sources</h3><p>Government and court websites prioritized throughout the directory.</p></div></div></div></div></section>
    <section class="quick-section"><div class="wrap"><p class="eyebrow">Quick Access</p><h2 class="h2">Most Searched States</h2><div class="state-buttons" id="quickStates"></div></div></section>
    <section id="business" class="section"><div class="wrap"><p class="eyebrow">Business records</p><h2 class="h2" id="businessTitle">Business Entity Search by State</h2><p class="desc">Open official business entity search tools for LLCs, corporations, registered agents, and filings.</p><div class="grid3"><article class="card"><div class="icon">🏢</div><h3 id="businessCardTitle">Select a State First</h3><p id="businessCardText">Choose a state above to display the official business search link.</p><a id="businessLink" class="btn" href="#" target="_blank">Open Search</a></article><article class="card"><div class="icon">📄</div><h3>Business Filing Tips</h3><p>Search by exact name, partial name, officer, registered agent, or entity number when available.</p></article><div><p class="ad-label">Advertisement</p><div class="ad-box small"></div></div></div></div></section>
    <section id="court" class="section alt"><div class="wrap"><p class="eyebrow">Lawsuit records</p><h2 class="h2" id="courtTitle">Lawsuit Records by State and County</h2><p class="desc" id="courtDesc">Select a state from the hero section above to load county court records.</p><div class="grid3"><article class="card"><div class="icon">⚖</div><h3 id="courtCardTitle">Select a State First</h3><p>Use official court and clerk resources for lawsuit and civil case records.</p></article><div class="panel"><h3>Choose County</h3><select id="countySelect"><option>Select a state above first</option></select><a id="lawsuitLink" class="btn" href="https://www.ncsc.org/information-and-resources/state-court-websites" target="_blank" style="margin-top:14px;width:100%">Court Directory</a></div><div><p class="ad-label">Advertisement</p><div class="ad-box small"></div></div></div></div></section>
    <section class="section" style="padding:24px 0"><div class="wrap"><p class="ad-label">Advertisement</p><div class="ad-box small"></div></div></section>
    <section id="bankruptcy" class="section"><div class="wrap"><p class="eyebrow">Federal records</p><h2 class="h2">Bankruptcy & Federal Case Search</h2><p class="desc">Search federal bankruptcy and court systems using PACER and related legal research tools.</p><div class="panel form-row"><input id="nameInput" placeholder="Person or business name"><a class="btn" href="https://pcl.uscourts.gov/pcl/index.jsf" target="_blank">Continue to PACER</a></div><div class="grid3"><article class="card"><div class="icon">📄</div><h3>CourtListener</h3><p>Free federal court opinions, RECAP archives, and docket research tools.</p><a class="btn" href="https://www.courtlistener.com/" target="_blank">Open Search</a></article><article class="card"><div class="icon">🔎</div><h3>Docket Alarm</h3><p>Advanced litigation analytics, federal court dockets, and legal intelligence tools.</p><a class="btn" href="https://www.docketalarm.com/" target="_blank">Open Search</a></article><article class="card"><div class="icon">🏢</div><h3>UniCourt</h3><p>Enterprise court analytics, litigation tracking, and federal docket intelligence platform.</p><a class="btn" href="https://unicourt.com/" target="_blank">Open Search</a></article></div></div></section>
    <section id="inmates" class="section alt"><div class="wrap"><p class="eyebrow">Incarceration records</p><h2 class="h2">Incarceration Records</h2><p class="desc" id="inmateDesc">Select a state above to load state incarceration records, or use the federal inmate locator below.</p><div class="panel form-row"><input placeholder="First and last name"><a id="inmateLink" class="btn" href="https://www.usa.gov/state-corrections" target="_blank">Open State Directory</a></div><div class="grid3"><article class="card"><div class="icon">🛡</div><h3>Federal Inmate Locator</h3><p>Search Bureau of Prisons records for federal inmates.</p><a class="btn" href="https://www.bop.gov/inmateloc/" target="_blank">Open Search</a></article><article class="card"><div class="icon">👥</div><h3>County Jail Directory</h3><p>Search county jail rosters and local detention records.</p><a class="btn" href="https://www.usa.gov/local-governments" target="_blank">Open Search</a></article><div><p class="ad-label">Advertisement</p><div class="ad-box small"></div></div></div></div></section>
    <section id="sex" class="section"><div class="wrap"><p class="eyebrow">Public safety</p><h2 class="h2">National Sex Offender Registry</h2><p class="desc">Search the official NSOPW registry by name or address-radius lookup.</p><div class="grid2"><div class="panel"><h3>Name Lookup</h3><input placeholder="First and last name"><a class="btn" href="https://www.nsopw.gov/search-public-sex-offender-registries" target="_blank" style="margin-top:14px;width:100%">Open Name Search</a></div><div class="panel"><h3>Address Radius Lookup</h3><input placeholder="Street address"><div class="form-row" style="grid-template-columns:1fr 120px"><input placeholder="City"><input placeholder="State"></div><div class="form-row" style="grid-template-columns:1fr 120px"><input placeholder="ZIP code"><select><option>1 Mile</option><option selected>5 Miles</option><option>10 Miles</option><option>25 Miles</option></select></div><a class="btn dark" href="https://www.nsopw.gov/search-public-sex-offender-registries" target="_blank" style="margin-top:14px;width:100%">Open Address Search</a></div></div></div></section>
    <section class="section"><div class="wrap"><div class="panel"><p class="eyebrow">Most Popular Searches</p><h2 class="h2">Most Searched States</h2><div class="chips" id="chips"></div></div><div style="margin-top:30px"><p class="ad-label">Advertisement</p><div class="ad-box"></div></div></div></section>
  </main>
  <footer class="footer"><div class="wrap footer-row"><img class="logo" src="./recordwatchdog-logo.png" alt="RecordWatchdog logo"><div class="footer-links"><button onclick="openModal('privacy')">Privacy Policy</button><button onclick="openModal('terms')">Terms</button><button onclick="openModal('about')">About</button><button onclick="openModal('contact')">Contact</button><button onclick="openModal('dmca')">DMCA</button></div></div></footer>
  <div class="modal" id="modal"><div class="modal-card"><button class="close" onclick="closeModal()">×</button><p class="eyebrow">Legal</p><h2 class="h2" id="modalTitle">Legal</h2><div id="modalBody" style="line-height:1.7;color:#475569"></div></div></div>
  <script>
    const states=[['All States',''],['Alabama','https://arc-sos.state.al.us/CGI/CORPNAME.MBR/INPUT'],['Alaska','https://www.commerce.alaska.gov/cbp/main/search/entities'],['Arizona','https://ecorp.azcc.gov/EntitySearch/Index'],['Arkansas','https://www.sos.arkansas.gov/corps/search_all.php'],['California','https://bizfileonline.sos.ca.gov/search/business'],['Colorado','https://www.sos.state.co.us/biz/BusinessEntityCriteriaExt.do'],['Connecticut','https://service.ct.gov/business/s/onlinebusinesssearch'],['Delaware','https://icis.corp.delaware.gov/Ecorp/EntitySearch/NameSearch.aspx'],['Florida','https://search.sunbiz.org/Inquiry/CorporationSearch/ByName'],['Georgia','https://ecorp.sos.ga.gov/BusinessSearch'],['Hawaii','https://hbe.ehawaii.gov/documents/search.html'],['Idaho','https://sosbiz.idaho.gov/search/business'],['Illinois','https://apps.ilsos.gov/businessentitysearch/'],['Indiana','https://bsd.sos.in.gov/publicbusinesssearch'],['Iowa','https://sos.iowa.gov/search/business/search.aspx'],['Kansas','https://www.kansas.gov/bess/flow/main?execution=e1s1'],['Kentucky','https://web.sos.ky.gov/ftsearch/'],['Louisiana','https://coraweb.sos.la.gov/commercialsearch/commercialsearch.aspx'],['Maine','https://icrs.informe.org/nei-sos-icrs/ICRS?MainPage=x'],['Maryland','https://egov.maryland.gov/BusinessExpress/EntitySearch'],['Massachusetts','https://corp.sec.state.ma.us/corpweb/CorpSearch/CorpSearch.aspx'],['Michigan','https://cofs.lara.state.mi.us/SearchApi/Search/Search'],['Minnesota','https://mblsportal.sos.state.mn.us/Business/Search'],['Mississippi','https://businesssearch.sos.ms.gov/corp/soskb/csearch.asp'],['Missouri','https://bsd.sos.mo.gov/BusinessEntity/BESearch.aspx'],['Montana','https://biz.sosmt.gov/search/business'],['Nebraska','https://www.nebraska.gov/sos/corp/corpsearch.cgi'],['Nevada','https://esos.nv.gov/EntitySearch/OnlineEntitySearch'],['New Hampshire','https://quickstart.sos.nh.gov/online/BusinessInquire'],['New Jersey','https://www.njportal.com/DOR/BusinessNameSearch/Search/BusinessName'],['New Mexico','https://portal.sos.state.nm.us/BFS/online/CorporationBusinessSearch'],['New York','https://apps.dos.ny.gov/publicInquiry/'],['North Carolina','https://www.sosnc.gov/online_services/search/by_title/_Business_Registration'],['North Dakota','https://firststop.sos.nd.gov/search/business'],['Ohio','https://businesssearch.ohiosos.gov/'],['Oklahoma','https://www.sos.ok.gov/corp/corpInquiryFind.aspx'],['Oregon','https://sos.oregon.gov/business/Pages/find.aspx'],['Pennsylvania','https://file.dos.pa.gov/search/business'],['Rhode Island','https://business.sos.ri.gov/CorpWeb/CorpSearch/CorpSearch.aspx'],['South Carolina','https://businessfilings.sc.gov/BusinessFiling/Entity/Search'],['South Dakota','https://sosenterprise.sd.gov/BusinessServices/Business/FilingSearch.aspx'],['Tennessee','https://tnbear.tn.gov/Ecommerce/FilingSearch.aspx'],['Texas','https://mycpa.cpa.state.tx.us/coa/'],['Utah','https://secure.utah.gov/bes/'],['Vermont','https://bizfilings.vermont.gov/online/BusinessInquire'],['Virginia','https://cis.scc.virginia.gov/EntitySearch/Index'],['Washington','https://ccfs.sos.wa.gov/#/BusinessSearch'],['West Virginia','https://apps.sos.wv.gov/business/corporations/'],['Wisconsin','https://www.wdfi.org/apps/CorpSearch/Search.aspx'],['Wyoming','https://wyobiz.wyo.gov/Business/FilingSearch.aspx']];
    const court={California:'https://www.courts.ca.gov/find-my-court.htm',Florida:'https://www.flcourts.gov/',Texas:'https://www.txcourts.gov/','New York':'https://www.nycourts.gov/',Illinois:'https://www.illinoiscourts.gov/',Georgia:'https://georgiacourts.gov/'};
    const inmate={California:'https://ciris.mt.cdcr.ca.gov/',Florida:'https://pubapps.fdc.myflorida.com/OffenderSearch/Search.aspx?TypeSearch=AI',Illinois:'https://idoc.illinois.gov/offender/inmatesearch.html','New York':'https://nysdoccslookup.doccs.ny.gov/',Texas:'https://inmate.tdcj.texas.gov/InmateSearch/start.action'};
    const counties={Florida:[['Miami-Dade County','https://www2.miamidadeclerk.gov/ocs/'],['Broward County','https://www.browardclerk.org/web2'],['Orange County','https://myeclerk.myorangeclerk.com/'],['Palm Beach County','https://appsgp.mypalmbeachclerk.com/eCaseView/']],California:[['Los Angeles County','https://www.lacourt.ca.gov/pages/lp/access-a-case/tp/find-case-information/cp/os-civil-case-access']],Texas:[['Harris County','https://www.hcdistrictclerk.com/edocs/public/search.aspx'],['Dallas County','https://courtsportal.dallascounty.org/DALLASPROD']],Illinois:[['Cook County','https://www.cookcountyclerkofcourt.org/online-case-information']],'New York':[['Albany County','https://iapps.courts.state.ny.us/nyscef/CaseSearch?task=new'],['Bronx County','https://iapps.courts.state.ny.us/nyscef/CaseSearch?task=new'],['Kings County','https://iapps.courts.state.ny.us/nyscef/CaseSearch?task=new'],['New York County','https://iapps.courts.state.ny.us/nyscef/CaseSearch?task=new'],['Queens County','https://iapps.courts.state.ny.us/nyscef/CaseSearch?task=new']]};
    const stateSelect=document.getElementById('stateSelect'); states.forEach(([n])=>stateSelect.add(new Option(n,n))); stateSelect.onchange=()=>updateState(stateSelect.value);
    function scrollToId(id){document.getElementById(id)?.scrollIntoView({behavior:'smooth'})} function popular(s,id){stateSelect.value=s;updateState(s);scrollToId(id)}
    function updateState(s){const entry=states.find(x=>x[0]===s);const has=s&&s!=='All States';document.getElementById('businessTitle').textContent=has?`${s} Business Entity Search`:'Business Entity Search by State';document.getElementById('businessCardTitle').textContent=has?`${s} Entity Search`:'Select a State First';document.getElementById('businessCardText').textContent=has?'Look up official Secretary of State business filings.':'Choose a state above to display the official business search link.';document.getElementById('businessLink').href=has?entry[1]:'#';document.getElementById('courtTitle').textContent=has?`${s} Lawsuit Records`:'Lawsuit Records by State and County';document.getElementById('courtDesc').textContent=has?`Choose a county within ${s} to open lawsuit and civil case lookup tools.`:'Select a state from the hero section above to load county court records.';document.getElementById('courtCardTitle').textContent=has?`${s} Court Directory`:'Select a State First';document.getElementById('lawsuitLink').href=has?(court[s]||'https://www.ncsc.org/information-and-resources/state-court-websites'):'https://www.ncsc.org/information-and-resources/state-court-websites';const csel=document.getElementById('countySelect');csel.innerHTML=''; if(has && counties[s]){csel.add(new Option('Select County',''));counties[s].forEach(([n,u])=>csel.add(new Option(n,u)));}else{csel.add(new Option(has?'No county shortcuts yet':'Select a state above first',''));} csel.onchange=()=>{if(csel.value)document.getElementById('lawsuitLink').href=csel.value};document.getElementById('inmateDesc').textContent=has?`Search ${s} correctional records or federal inmate custody records.`:'Select a state above to load state incarceration records, or use the federal inmate locator below.';document.getElementById('inmateLink').href=has&&(inmate[s])?inmate[s]:'https://www.usa.gov/state-corrections';document.getElementById('inmateLink').textContent=has?`Open ${s} Search`:'Open State Directory';}
    ['Florida','California','Texas','New York','Illinois','Georgia'].forEach(s=>{let b=document.createElement('button');b.className='state-btn';b.innerHTML=`<strong>${s}</strong><br><small>Popular public record searches</small>`;b.onclick=()=>popular(s,'business');document.getElementById('quickStates').appendChild(b)});
    ['Florida Public Records','California Court Records','Texas Business Search','New York Inmate Search','Illinois Court Search','Georgia Business Entity Search','Delaware LLC Search','Florida Arrest Records'].forEach(t=>{let b=document.createElement('button');b.className='chip';b.textContent=t;b.onclick=()=>popular(t.includes('Florida')?'Florida':t.includes('California')?'California':t.includes('Texas')?'Texas':t.includes('New York')?'New York':t.includes('Illinois')?'Illinois':t.includes('Georgia')?'Georgia':'Delaware',t.includes('Court')?'court':t.includes('Inmate')?'inmates':'business');document.getElementById('chips').appendChild(b)});
    const modalText={privacy:['Privacy Policy','RecordWatchdog respects your privacy and is designed primarily as a directory of official public-record resources. We do not host records directly on our servers. Users should verify all records directly with the official source.'],terms:['Terms of Use','RecordWatchdog is an informational directory and is not a consumer reporting agency under the Fair Credit Reporting Act.'],about:['About RecordWatchdog','RecordWatchdog organizes business records, court records, incarceration records, bankruptcy resources, and registry search tools into one streamlined public-records directory.'],contact:['Contact Us','For general inquiries, corrections, business opportunities, or legal requests, please contact: niko@nwbventures.com'],dmca:['DMCA Policy','RecordWatchdog respects intellectual property rights. For DMCA notices, contact: niko@nwbventures.com']};function openModal(k){document.getElementById('modalTitle').textContent=modalText[k][0];document.getElementById('modalBody').innerHTML='<p>'+modalText[k][1]+'</p>';document.getElementById('modal').classList.add('active')}function closeModal(){document.getElementById('modal').classList.remove('active')}
  </script>
</body>
</html>
